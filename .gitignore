# Dependency folders (ყველაზე დიდი ფოლდერები, რაც არ უნდა აიტვირთოს)
node_modules/

# Environment variables (პაროლები და სეკრეტები)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs (ფრონტის აწყობილი ვერსიები)
dist
.next/
out/

# Logs (ერორების ლოგები)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE settings (შენი რედაქტორის პარამეტრები)
.vscode/
.idea/
.DS_Store (Mac-ისთვის)